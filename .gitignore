# Ignore Node modules and logs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.pnpm-debug.log*

# Build output
dist/
build/
out/

# Temporary files and caches
.cache/
.tmp/
.parcel-cache/

# Environment files
.env
.env.local
.env.*.local

# System files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Terraform (if used for AWS infra)
.terraform/
terraform.tfstate
terraform.tfstate.*
crash.log
override.tfvars
override.tfvars.json

# AWS CLI credentials
.aws/

# Python virtualenvs (if any)
venv/
ENV/
env/

# Cache / compiled files
__pycache__/
*.py[cod]

# Coverage and reports
coverage/
reports/

# Logs
*.log

# Distribution archives
dist-zip/
